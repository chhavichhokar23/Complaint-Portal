generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
  EMPLOYEE
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ResolutionType {
  EMPLOYEE_NOTE
  ADMIN_RESOLUTION
  ADMIN_TO_EMPLOYEE
  REJECTION
  REOPEN_NOTE
}

enum ComplaintStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CLOSED
  RESOLVED
  REJECTED
  PENDING
}

model ComplaintResolution {
  id          String         @id @default(cuid())
  complaintId String
  message     String
  type        ResolutionType
  createdById String         @db.Uuid
  createdAt   DateTime       @default(now())

  complaint   Complaint      @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  createdBy   User           @relation(fields: [createdById], references: [id])

  @@index([complaintId])
}

model DepartmentMaster {
  name String @id
}

model CategoryMaster {
  name          String              @id
  department    String
  prefix        String?             @unique
  subcategories SubcategoryMaster[]
}

model SubcategoryMaster {
  id           String         @id @default(cuid())
  name         String
  categoryName String
  category     CategoryMaster @relation(fields: [categoryName], references: [name], onDelete: Cascade)
}

model PriorityMaster {
  id            String             @id @default(cuid())
  name          String             @unique  
  slaHours      Int?
  
  complaints         Complaint[]
  organisationDefaults OrganisationMaster[] @relation("DefaultPriority")
  slaEntries    SlaMaster[]
  systemSettings       SystemSettings[] 
}

model OrganisationMaster {
  id                String         @id @default(cuid())
  name              String         @unique
  defaultPriorityId String?
  defaultPriority   PriorityMaster? @relation("DefaultPriority", fields: [defaultPriorityId], references: [id])

  users    User[]
  slaRules SlaMaster[]
}
model SystemSettings {
  id                    String @id @default("system") 
  defaultSlaHours       Int    @default(72)
  defaultPriorityId     String?
  defaultPriority       PriorityMaster? @relation(fields: [defaultPriorityId], references: [id])
}
model SlaMaster {
  id             String             @id @default(cuid())
  organisationId String
  organisation   OrganisationMaster @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  priorityId     String
  priority       PriorityMaster     @relation(fields: [priorityId], references: [id], onDelete: Cascade)
  timeline       Int                // hours

  @@unique([organisationId, priorityId]) 
}

model User {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  email              String              @unique
  password           String
  role               Role
  department         String?
  mobileNumber       String?
  organisationId     String?
  organisation       OrganisationMaster? @relation(fields: [organisationId], references: [id])
  registrationStatus RegistrationStatus  @default(APPROVED)
  createdAt          DateTime            @default(now())

  complaints         Complaint[]
  assignedComplaints Complaint[]         @relation("AssignedComplaints")
  resolutions ComplaintResolution[]  
}

model Complaint {
  id           String  @id @default(cuid())
  ticketNumber String? @unique

  category     String
  subcategory  String?
  mobileNumber String?
  description  String

  status      ComplaintStatus @default(OPEN)
  priorityId  String?
  priority    PriorityMaster? @relation(fields: [priorityId], references: [id])
  slaDeadline DateTime?

  resolutionMessage String?
  rejectionReason   String?

  customerId   String @db.Uuid
  customer     User   @relation(fields: [customerId], references: [id])

  assignedToId String? @db.Uuid
  assignedTo   User?   @relation("AssignedComplaints", fields: [assignedToId], references: [id])

  createdAt   DateTime              @default(now())
  feedbacks   ComplaintFeedback[]
  attachments ComplaintAttachment[]
  resolutions ComplaintResolution[]
}

model ComplaintAttachment {
  id          String   @id @default(cuid())
  complaintId String
  fileName    String
  fileUrl     String
  fileType    String
  createdAt   DateTime @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
}

model ComplaintFeedback {
  id          String   @id @default(uuid())
  complaintId String
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
}
